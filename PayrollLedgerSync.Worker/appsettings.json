{
  "ConnectionStrings": {
    "PayrollLedger": "Server=(localdb)\\MSSQLLocalDB;Database=PayrollLedgerSyncDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "payroll.ledger.events",
    "ExchangeType": "topic"
  },
  "OutboxProcessor": {
    "PollingIntervalSeconds": 5,
    "BatchSize": 20,
    "MaxRetryCount": 5,
    "ProcessedBy": "outbox-processor"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
